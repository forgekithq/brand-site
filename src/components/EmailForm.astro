---
---

<form id="email-form" class="flex w-full max-w-md flex-col gap-3 sm:flex-row">
  <label for="email-input" class="sr-only">Email address</label>
  <input
    id="email-input"
    type="email"
    name="email"
    required
    placeholder="you@example.com"
    autocomplete="email"
    class="flex-1 rounded-lg border border-white/10 bg-brand-surface/50 px-4 py-3 text-sm text-brand-text placeholder-brand-muted outline-none transition-colors focus:border-brand-accent/50 focus:ring-1 focus:ring-brand-accent/30"
  />
  <!-- Honeypot field — hidden from humans, catches bots -->
  <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />
  <button
    type="submit"
    class="animate-glow rounded-lg bg-brand-accent px-6 py-3 text-sm font-semibold text-brand-bg transition-opacity hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed"
  >
    Notify me
  </button>
</form>

<div id="form-message" class="mt-3 text-sm" aria-live="polite"></div>

<script>
  const form = document.getElementById('email-form') as HTMLFormElement;
  const message = document.getElementById('form-message') as HTMLDivElement;
  const button = form.querySelector('button') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);
    const email = formData.get('email') as string;
    const honeypot = formData.get('website') as string;

    // Bot detected
    if (honeypot) return;

    button.disabled = true;
    message.textContent = '';

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      if (res.ok) {
        const data = await res.json();
        message.textContent = data.message ?? "Thanks! We'll keep you posted.";
        message.className = 'mt-3 text-sm text-brand-accent';
        form.reset();
      } else {
        const data = await res.json().catch(() => null);
        message.textContent = data?.error ?? 'Something went wrong. Try again later.';
        message.className = 'mt-3 text-sm text-red-400';
      }
    } catch {
      message.textContent = 'Something went wrong. Try again later.';
      message.className = 'mt-3 text-sm text-red-400';
    } finally {
      button.disabled = false;
    }
  });
</script>
